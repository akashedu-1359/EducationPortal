# ─────────────────────────────────────────────────────────────────────────────
# .env.local — local developer secrets
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and NEVER committed.
#
# For CI/CD, these values are injected via GitHub Secrets per environment:
#   GitHub → Settings → Environments → {development|qa|production} → Secrets
# ─────────────────────────────────────────────────────────────────────────────

# Auth — Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# ISR Revalidation (server-side only — NOT NEXT_PUBLIC)
REVALIDATION_SECRET=generate-a-strong-random-string-here

# Optional: override JSON config defaults locally
# NEXT_PUBLIC_API_URL=http://localhost:5000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_NAME=EduPortal
