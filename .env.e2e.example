# Copy this to .env.e2e and fill in values before running tests
# Never commit .env.e2e — it contains test credentials

# Target environment (defaults to localhost:3000 if not set)
PLAYWRIGHT_BASE_URL=https://education-portal-rpvr.vercel.app
PLAYWRIGHT_API_URL=https://eduportal-backend-ssg4.onrender.com

# Admin account (must have SuperAdmin role in DB)
E2E_ADMIN_EMAIL=your-admin@example.com
E2E_ADMIN_PASSWORD=YourPassword@123

# Regular user account (auto-created by setup if not set)
E2E_USER_EMAIL=testuser@example.com
E2E_USER_PASSWORD=TestUser@123
